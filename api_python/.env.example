# Arquivo de exemplo de configuração do FinAI API
# Copie este arquivo para .env e preencha com seus valores reais.
# ⚠️  NUNCA faça commit do arquivo .env real no Git!

# --- Supabase ---
# Encontre em: Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Chave JWT para validação offline de tokens de usuário.
# Encontre em: Supabase Dashboard > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# --- Modelos de IA ---
# Groq (primário): https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# Gemini (fallback): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# --- CORS (Produção) ---
# Em produção, substitua com a URL real do seu frontend.
# Formato de lista JSON: ["https://meuapp.com","https://www.meuapp.com"]
# ORIGINS=["https://meuapp.com"]